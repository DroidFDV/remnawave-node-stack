# Скопируйте в .env и задайте реальные значения.
# Передаётся в контейнер как DOMAIN (server_name в nginx)
NGINX_DOMAIN=example.domain
# Email для Let's Encrypt (acme.sh). См. scripts/bootstrap-host.sh
SSL_EMAIL=you@example.com
# Каталог относительно корня репозитория (как ./nginx в docker-compose)
NGINX_SSL_DIR=./nginx
# Webroot для HTTP-01: acme.sh -w <этот_каталог> при ACME_ISSUE_METHOD=webroot
NGINX_ACME_WEBROOT=./nginx/acme-webroot
# webroot (по умолчанию: временный PEM, compose up, LE webroot) | standalone
ACME_ISSUE_METHOD=webroot

# Nginx: фрагменты для assemble-nginx.sh (см. nginx/README.md)
# xhttp | grpc | ws — хотя бы один; через запятую без пробелов
# Пример с WebSocket: NGINX_PARTS=xhttp,grpc,ws
NGINX_PARTS=xhttp,grpc
# decoy (HTML на /) | drop444 (молчаливый обрыв)
NGINX_FALLBACK=decoy

# Hysteria2 (Config Profile в Panel, не nginx)
# UDP-порт inbound HY2 на ноде (по умолчанию 443; ufw открывает HY2_UDP_PORT/udp)
HY2_UDP_PORT=443
# Опционально: диапазон udpHop в finalmask.quicParams, напр. 20000:50000
# HY2_UDP_HOP_PORTS=20000:50000
# salamander | gecko — для документации; пароль задаётся в JSON профиля Panel
HY2_OBFS_MODE=salamander
HY2_OBFS_PASSWORD=replace-with-strong-password

# Передаётся в контейнер как NODE_PORT
REMNANODE_NODE_PORT=1234
# Передаётся в контейнер как SECRET_KEY
REMNANODE_SECRET_KEY=replace-with-your-panel-secret
